# =============================================================================
# Compass — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA comite .env.local — ele está no .gitignore.
# =============================================================================

# Supabase (projeto Compass — papgnqzrkpbicuzkfzcr na org LK Labs)
NEXT_PUBLIC_SUPABASE_URL=https://papgnqzrkpbicuzkfzcr.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Service role (server-side apenas — edge functions, scripts admin)
# NÃO expor no client. Não usar em código client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email transacional) ─────────────────────────────────────────────
# Sem RESEND_API_KEY o envio é pulado silenciosamente. A criação de usuário
# continua funcionando — o admin copia a senha do dialog manualmente.
# Gere em https://resend.com → API Keys → Sending access (após verificar o
# domínio do remetente no painel).
RESEND_API_KEY=
# Remetente. Antes do domínio estar verificado, use "onboarding@resend.dev"
# (sandbox — só envia pro email da conta Resend).
EMAIL_FROM="Nexus <no-reply@magictrips.com.br>"

# URL pública do app (usada em emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mesma URL, mas server-only (usada nos templates de email).
APP_URL=http://localhost:3000

# Supabase (projeto Compass — papgnqzrkpbicuzkfzcr na org LK Labs)
NEXT_PUBLIC_SUPABASE_URL=https://papgnqzrkpbicuzkfzcr.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Service role (server-side apenas — edge functions, scripts admin)
